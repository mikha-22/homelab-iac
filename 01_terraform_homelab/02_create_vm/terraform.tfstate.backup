            "overwrite": true,
            "source_file": [],
            "source_raw": [
              {
                "data": "#cloud-config\nusers:\n  - name: mikha\n    sudo: ALL=(ALL) NOPASSWD:ALL\n    groups: users, admin\n    shell: /bin/bash\n    ssh_authorized_keys:\n      - ssh-rsa  milenikaiqbal@gmail.com\n      \n# Install only the necessary packages for a minimal VM.\n# The rest will be configured by Ansible.\npackages:\n  - qemu-guest-agent\n\n# Ensure the guest agent is running.\nruncmd:\n  - systemctl enable --now qemu-guest-agent\n",
                "file_name": "webserver-init.yaml",
                "resize": 0
              }
            ],
            "timeout_upload": 1800
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
      ]
